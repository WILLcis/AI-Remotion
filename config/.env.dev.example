# AI-Remotion local development placeholder.
# Keep keys in sync with config/.env.prod.example.
NODE_ENV=development

# AI-Remotion runtime provider config.
AI_REMOTION_ENV_FILE=
AI_REMOTION_LLM_PROVIDER=deterministic
AI_REMOTION_LLM_BASE_URL=
AI_REMOTION_LLM_API_KEY=
AI_REMOTION_LLM_MODEL=
AI_REMOTION_LLM_TEMPERATURE=0.4
AI_REMOTION_LLM_TIMEOUT_MS=60000
AI_REMOTION_LLM_FALLBACK_TO_DETERMINISTIC=true
AI_REMOTION_TTS_PROVIDER=silent
AI_REMOTION_TTS_BASE_URL=
AI_REMOTION_TTS_API_KEY=
AI_REMOTION_TTS_MODEL=
AI_REMOTION_TTS_VOICE=
AI_REMOTION_TTS_TIMEOUT_MS=60000

# Harness placeholders.
TTS_PROVIDER=none
LLM_PROVIDER=mock
OBSERVABILITY_BACKEND=mock
TRACKER=github-dryrun
