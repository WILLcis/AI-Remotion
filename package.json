{
  "name": "ai-remotion",
  "version": "0.9.1",
  "private": true,
  "description": "Local-first AI + Remotion agent for image-and-text explainer videos.",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/WILLcis/AI-Remotion.git"
  },
  "license": "UNLICENSED",
  "scripts": {
    "dev": "remotion studio src/remotion/index.ts",
    "build": "remotion bundle src/remotion/index.ts",
    "check": "npm run typecheck && npm run lint && npm run validate:sample && npm test && npm audit --audit-level=low",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "test": "vitest run",
    "test:unit": "vitest run",
    "episode:batch": "tsx src/cli/runBatch.ts",
    "episode:captions": "tsx src/cli/generateCaptions.ts",
    "episode:new": "tsx src/cli/createEpisode.ts",
    "episode:qa": "tsx src/cli/generateQaReport.ts",
    "episode:render": "tsx src/cli/renderEpisode.ts",
    "episode:render-plan": "tsx src/cli/generateRenderPlan.ts",
    "episode:route": "tsx src/cli/routeRevision.ts",
    "episode:script": "tsx src/cli/generateScript.ts",
    "episode:storyboard": "tsx src/cli/generateStoryboard.ts",
    "episode:validate": "tsx src/cli/validateEpisode.ts",
    "episode:voice": "tsx src/cli/generateVoiceover.ts",
    "validate:sample": "npm run episode:validate -- --episode sample",
    "verify:harness": "bash tools/verify.sh",
    "render:sample": "remotion render src/remotion/index.ts ExplainerVideo episodes/sample/out/final.mp4 --props=episodes/sample/render-plan.json"
  },
  "sideEffects": [
    "*.css"
  ],
  "dependencies": {
    "@remotion/cli": "4.0.485",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "remotion": "4.0.485",
    "yaml": "2.9.0",
    "zod": "4.3.6"
  },
  "devDependencies": {
    "@remotion/eslint-config-flat": "4.0.485",
    "@types/node": "24.10.1",
    "@types/react": "19.2.7",
    "@types/web": "0.0.166",
    "eslint": "9.39.4",
    "prettier": "3.8.1",
    "tsx": "4.23.0",
    "typescript": "5.9.3",
    "vitest": "4.1.10"
  }
}
